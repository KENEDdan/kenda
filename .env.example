# Django core
SECRET_KEY=your-very-long-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=kenda_project.settings.development

# Database
DATABASE_URL=postgres://kenda_user:your_password@localhost:5432/kenda_db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Email
EMAIL_HOST=smtp.sendgrid.net
SENDGRID_API_KEY=your-sendgrid-key
DEFAULT_FROM_EMAIL=noreply@kendaplatform.com

# Sentry
SENTRY_DSN=https://your-dsn@sentry.io/project

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=kenda-media
AWS_S3_REGION_NAME=af-south-1